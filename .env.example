# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/scanox

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_business_api_token

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay Item IDs for different print types
ITEM_BW=item_id_for_black_white_single_side
ITEM_BW_T=item_id_for_black_white_both_sides
ITEM_C=item_id_for_color_single_side
ITEM_C_T=item_id_for_color_both_sides

# Security Keys
AES_KEY=base64_encoded_32_byte_aes_256_gcm_key
WEBHOOK_SECRET=your_webhook_verification_secret
CLIENT_SECRET=your_api_client_authentication_token

# Server Configuration
PORT=8000
